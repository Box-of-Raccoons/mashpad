__pycache__/
*.pyc
.pytest_cache/
# Grown-up options persist here at runtime — device-local, never committed.
settings.json
# BabyIDE resume cursor persists here at runtime — device-local, never committed.
babyide_state.json
# Generated at install time by gen_voice.py / gen_effects.py / gen_notes.py —
# never committed.
sounds/voice/*.wav
sounds/effects/*.wav
sounds/notes/*.wav
tools/node_modules/
tools/raw/
tools/stickers/
tools/package*.json
# API keys (gen tools read GEMINI_VOICE_KEY* from here)
.env
packaging/build/
packaging/dist/
packaging/out/
# Playwright-MCP session artifacts (console/page dumps) — never committed.
.playwright-mcp/
